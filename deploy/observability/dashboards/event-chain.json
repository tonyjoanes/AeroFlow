{
  "title": "AeroFlow — Event Chain",
  "uid": "aeroflow-event-chain",
  "tags": ["aeroflow"],
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Events Published — Rate (per service)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service, subject) (rate(aeroflow_events_published_total[1m]))",
          "legendFormat": "{{service}} → {{subject}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 2,
      "title": "Events Consumed — Rate (per service)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service, subject) (rate(aeroflow_events_consumed_total[1m]))",
          "legendFormat": "{{service}} ← {{subject}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "title": "Consumer Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service) (rate(aeroflow_events_consumed_total{result=\"error\"}[1m]))",
          "legendFormat": "{{service}} errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "title": "Event Processing Latency — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (service, le) (rate(aeroflow_event_processing_duration_seconds_bucket[1m])))",
          "legendFormat": "{{service}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(aeroflow_event_processing_duration_seconds_bucket[1m])))",
          "legendFormat": "{{service}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (service, le) (rate(aeroflow_event_processing_duration_seconds_bucket[1m])))",
          "legendFormat": "{{service}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 5,
      "title": "Total Events Published (counter)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(aeroflow_events_published_total)",
          "legendFormat": "total published"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Total Events Consumed (counter)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(aeroflow_events_consumed_total{result=\"ok\"})",
          "legendFormat": "total consumed ok"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "title": "Total Errors",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "options": { "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(aeroflow_events_consumed_total{result=\"error\"})",
          "legendFormat": "errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Active Services",
      "type": "stat",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "count(count by (service) (aeroflow_events_published_total))",
          "legendFormat": "services"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ],
  "schemaVersion": 38
}
